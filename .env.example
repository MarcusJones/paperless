# .env.example — copy to .env and fill in your values
# NEVER commit .env to git — it is listed in .gitignore
#
# This file holds ONLY secrets. Non-secret config lives in each service's own
# <service>/.env file (those ARE committed — they contain no secrets).

# ── Paperless API token ───────────────────────────────────────────────────────
# How to get it (first-time setup):
#   1. docker compose up -d
#   2. docker compose exec paperless python3 manage.py createsuperuser
#   3. Log in at http://localhost:8000
#   4. Click your username → My Profile → API Token → copy it here
# Subsequent deploys: keep the same token — changing it breaks AI service config.
PAPERLESS_API_TOKEN=PASTE_YOUR_TOKEN_HERE

# ── PostgreSQL password ───────────────────────────────────────────────────────
# Password for the 'paperless' database user.
# Any non-empty string works locally.
# Generate: openssl rand -base64 18
PG_PASSWORD=

# ── Django secret key ─────────────────────────────────────────────────────────
# Signs session cookies and CSRF tokens. Changing this invalidates all sessions.
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
#       or: openssl rand -hex 32
SECRET_KEY=

# ── Dropbox / Windows username ────────────────────────────────────────────────
# Your Windows username — used to build the Dropbox consume path in scripts/backup.sh.
# The consume dir bind mount is ./paperless/consume — symlink it:
#   ln -s /mnt/c/Users/<DROPBOX_USER>/Dropbox/paperless-consume ./paperless/consume
DROPBOX_USER=YOURWINDOWSUSERNAME

# ── paperless-ai-next webhook API key ────────────────────────────────────────
# Secures the webhook endpoint POST http://paperless-ai-next:3000/api/webhook/document
# Set the same value in the Paperless-ngx Workflow webhook header: x-api-key: <this>
# Generate: openssl rand -hex 24
PAPERLESS_AI_NEXT_API_KEY=
