# .env.example — copy this to .env and fill in your values
# NEVER commit .env to git — it is listed in .gitignore

# ── Paperless API token ───────────────────────────────────────────────────────
# How to get it:
#   1. Run ./setup.sh, then: docker exec -it paperless python3 manage.py createsuperuser
#   2. Log in at http://localhost:8000
#   3. Click your username (top-right) → My Profile → API Token → copy it
#   4. Paste it here, then re-run: ./remove.sh && ./setup.sh
PAPERLESS_API_TOKEN=PASTE_YOUR_TOKEN_HERE

# ── Dropbox / Windows username ────────────────────────────────────────────────
# Your Windows username — used to build the Dropbox mount paths:
#   Consume: /mnt/c/Users/$DROPBOX_USER/Dropbox/paperless-consume
#   Backup:  /mnt/c/Users/$DROPBOX_USER/Dropbox/paperless-backup
DROPBOX_USER=YOURWINDOWSUSERNAME

# ── Django secret key ─────────────────────────────────────────────────────────
# Used to sign session cookies and tokens. Required even for local use —
# if it changes between runs, all active sessions are invalidated.
# Generate one: python3 -c "import secrets; print(secrets.token_hex(32))"
#            or: openssl rand -hex 32
SECRET_KEY=

# ── PostgreSQL password ───────────────────────────────────────────────────────
# Password for the paperless database user.
# Any non-empty string works locally. Use something strong for EC2.
# Generate one: openssl rand -base64 18
PG_PASSWORD=
