# paperless-gpt/.env — non-secret Vision OCR config
# PAPERLESS_API_TOKEN comes from root .env via compose.yaml.

# ── Paperless connection ──────────────────────────────────────────────────────
# PAPERLESS_API_TOKEN is injected from root .env (secret)
PAPERLESS_BASE_URL=http://paperless:8000

# ── Ollama / LLM ─────────────────────────────────────────────────────────────
LLM_PROVIDER=ollama
OLLAMA_HOST=http://host.docker.internal:11434
LLM_MODEL=qwen3-vl:8b

# ── OCR trigger tag ───────────────────────────────────────────────────────────
# paperless-gpt watches for this tag and runs vision OCR on matching documents.
# This tag is applied to new documents by the Paperless-ngx "Auto Vision OCR" Workflow.
AUTO_OCR_TAG=paperless-gpt-ocr-auto

# ── Post-OCR tag handoff ──────────────────────────────────────────────────────
# After OCR completes, paperless-gpt REMOVES AUTO_OCR_TAG and ADDS this tag.
# The Paperless-ngx "AI Classification after OCR" Workflow fires a webhook to
# paperless-ai-next when this tag is applied — triggering Stage 3.
PDF_OCR_TAGGING=true
PDF_OCR_COMPLETE_TAG=ai-process

# ── Auto-tagging mode ─────────────────────────────────────────────────────────
# Disabled — we use a separate AI classifier (paperless-ai-next) for tagging.
# paperless-gpt's role here is OCR only.
AUTO_TAG=
MANUAL_TAG=

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
