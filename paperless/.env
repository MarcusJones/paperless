# paperless/.env — non-secret Paperless-ngx config
# PAPERLESS_SECRET_KEY and PAPERLESS_DBPASS come from root .env via compose.yaml.

# ── Database ──────────────────────────────────────────────────────────────────
PAPERLESS_DBENGINE=postgresql
PAPERLESS_DBHOST=postgres
PAPERLESS_DBPORT=5432
PAPERLESS_DBNAME=paperless
PAPERLESS_DBUSER=paperless

# ── Redis ─────────────────────────────────────────────────────────────────────
PAPERLESS_REDIS=redis://redis:6379

# ── Tika + Gotenberg ──────────────────────────────────────────────────────────
PAPERLESS_TIKA_ENABLED=1
PAPERLESS_TIKA_ENDPOINT=http://tika:9998
PAPERLESS_TIKA_GOTENBERG_ENDPOINT=http://gotenberg:3000

# ── Locale & OCR ──────────────────────────────────────────────────────────────
PAPERLESS_TIME_ZONE=Europe/Vienna
PAPERLESS_OCR_LANGUAGE=deu+eng

# ── Consumer ──────────────────────────────────────────────────────────────────
# Polling required: inotify does not work across the WSL2/Windows Dropbox bridge.
PAPERLESS_CONSUMER_POLLING=10

# ── Bind-mount permissions ────────────────────────────────────────────────────
# Match the UID/GID of your WSL2 user (typically 1000).
# If files appear as owned by root after container start, adjust these.
USERMAP_UID=1000
USERMAP_GID=1000

# ── URL (used in email links, not for routing) ────────────────────────────────
PAPERLESS_URL=http://localhost:8000

# ── Admin ─────────────────────────────────────────────────────────────────────
PAPERLESS_ADMIN_USER=admin
